{
  "name": "vite-static",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:scss:pack && node tools/build-js-bundle.js && node tools/postbuild-html.js",
    "build:img": "node tools/optimize-images.js",
    "build:delivery": "vite build && npm run build:scss:pack && node tools/build-js-bundle.js && npm run build:img && node tools/postbuild-html.js",
    "build:scss": "node tools/prepare-scss.js && cd src/assets/scss && sass style.scss ../../../dist/assets/css/style.css --no-source-map --style=expanded --load-path=.",
    "build:scss:pack": "npm run build:scss && postcss dist/assets/css/style.css --replace",
    "lint": "eslint src/**/*.js",
    "preview": "vite preview"
  },
  "keywords": [],
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "chokidar": "^5.0.0",
    "css-declaration-sorter": "^7.2.0",
    "css-mqpacker": "^7.0.0",
    "eslint": "^9.39.2",
    "glob": "^11.0.0",
    "globals": "^16.5.0",
    "imagemin": "^9.0.0",
    "imagemin-cli": "^8.0.0",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^11.0.1",
    "imagemin-webp": "^8.0.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.1",
    "postcss-sort-media-queries": "^5.2.0",
    "sass": "^1.83.0",
    "vite": "^6.0.5",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-static-copy": "^2.1.0"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "jquery": "^3.7.1",
    "modal-video": "^2.4.8",
    "swiper": "^11.1.15"
  }
}
